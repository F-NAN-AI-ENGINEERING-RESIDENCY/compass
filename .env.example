# Database
DATABASE_URL=postgresql+psycopg2://compass_user:compass_password@localhost:5432/compass_db

# Auth
SESSION_EXPIRE_HOURS=24

# Video (Daily.co). Leave unset for local dev/tests — app.services.video falls
# back to a fake, network-free implementation whenever this is blank.
DAILY_API_KEY=

# AI Tutor (Gemini, temporary — swapping to Anthropic once API tokens are
# approved). Leave unset for local dev/tests — app.services.tutor falls back
# to a fake, network-free implementation whenever this is blank.
GEMINI_API_KEY=

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
