# Database
DATABASE_URL=postgresql+psycopg2://compass_user:compass_password@localhost:5432/compass_db

# Auth
SESSION_EXPIRE_HOURS=24

# Video (Daily.co) + transcription (OpenAI Whisper). Leave provider settings as
# "stub" for local dev/tests — app.services.video / app.services.transcription
# fall back to fake, network-free implementations whenever they're "stub".
VIDEO_PROVIDER=stub
TRANSCRIPTION_PROVIDER=stub
DAILY_API_KEY=
DAILY_WEBHOOK_SECRET=
OPENAI_API_KEY=

# App
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
